# ─── Docker Compose deploy ────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below (DATABASE_URL & REDIS_URL are set automatically)
# 3. Run:  docker compose up -d --build
# ──────────────────────────────────────────────────────────────────────────────

# Wise Old Man API — get a key at https://wiseoldman.net/discord
WOM_API_KEY=your_wom_api_key_here
WOM_USER_AGENT=YourAppName/1.0
WOM_BASE_URL=https://api.wiseoldman.net/v2

# Frontend origin (for CORS).  Keep as-is for local Docker deploy.
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# URL the *browser* uses to reach the API.  Keep as-is for local Docker deploy.
# For a remote server change to http://<server-ip>:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# BullMQ queue name
QUEUE_NAME=clan-sync-queue

# ── Local / non-Docker dev only (docker-compose sets these automatically) ─────
# PORT=3000
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clan_leagues_tracker?schema=public
# REDIS_URL=redis://127.0.0.1:6379
