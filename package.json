{
  "name": "clan-leagues-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack clan tracker with Express API and Next.js app",
  "main": "dist/server.js",
  "scripts": {
    "start": "sh start.sh",
    "dev": "npm run dev:infra && concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "npm --prefix frontend run dev",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:stop": "docker compose -f docker-compose.dev.yml down",
    "worker": "tsx src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "build:web": "npm --prefix frontend run build",
    "build:all": "npm run build ; npm run build:web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "jest --runInBand",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@wise-old-man/utils": "^4.0.14",
    "bullmq": "^5.17.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.4",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.0.1",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
